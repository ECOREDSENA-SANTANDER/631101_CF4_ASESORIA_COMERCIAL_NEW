total","length","porcentaje","forEach","r","esCorrecta","aprobado"],"sources":["src/components/actividad/ActividadResultados.vue"],"sourcesContent":["<template>\n  <div class=\"row align-items-center justify-content-around\">\n    <div class=\"col-5\">\n      <img\n        v-if=\"aprobado\"\n        src=\"@/assets/componentes/cuestionario-resultado.svg\"\n        alt=\"\"\n      />\n      <img\n        v-else\n        src=\"@/assets/componentes/cuestionario-resultado.svg\"\n        alt=\"\"\n      />\n    </div>\n    <div class=\"col-4\">\n      <div class=\"d-flex align-items-center flex-column\">\n        <div\n          class=\"resultados__icono mb-4\"\n          :class=\"[\n            `resultados__icono--${aprobado ? 'correcto' : 'incorrecto'}`,\n          ]\"\n        />\n        <template v-if=\"aprobado\">\n          <h3>¡BUEN TRABAJO!</h3>\n          <p class=\"mb-0 text-center\">\n            Se evidencia un buen manejo de los conceptos estudiados en esta\n            unidad.\n          </p>\n        </template>\n        <template v-else>\n          <h3>VUELVE A INTENTARLO</h3>\n          <p class=\"mb-0 text-center\">\n            Se recomienda revisar el contenido de la unidad para clarificar\n            conceptos.\n          </p>\n        </template>\n        <hr class=\"w-100\" />\n        <p class=\"mb-0\">Aciertos: {{ rtas.correctas }} / {{ rtas.total }}</p>\n      </div>\n    </div>\n  </div>\n</template>\n\n<script>\nexport default {\n  name: 'ActividadResultados',\n  props: {\n    respuestas: {\n      type: Array,\n      required: true,\n    },\n  },\n  computed: {\n    rtas() {\n      const respuestas = {\n        correctas: 0,\n        incorrectas: 0,\n        total: this.respuestas.length,\n        porcentaje: 0,\n      }\n      this.respuestas.forEach(r => {\n        if (r.esCorrecta) {\n          respuestas.correctas++\n        } else {\n          respuestas.incorrectas++\n        }\n      })\n      respuestas.porcentaje = (respuestas.correctas / respuestas.total) * 100\n      return respuestas\n    },\n    aprobado() {\n      return this.rtas.porcentaje >= 70\n    },\n  },\n}\n</script>\n\n<style lang=\"sass\" scoped>\n.resultados\n  &__icono\n    width: 150px\n    height: 150px\n    background-size: cover\n    background-repeat: no-repeat\n    &--correcto\n      background-image: url('~@/assets/actividad/correcto.svg')\n    &--incorrecto\n      background-image: url('~@/assets/actividad/incorrecto.svg')\n</style>\n"],"mappings":";;AA4CA;EACAA,IAAA;EACAC,KAAA;IACAC,UAAA;MACAC,IAAA,EAAAC,KAAA;MACAC,QAAA;IACA;EACA;EACAC,QAAA;IACAC,KAAA;MACA,MAAAL,UAAA;QACAM,SAAA;QACAC,WAAA;QACAC,KAAA,OAAAR,UAAA,CAAAS,MAAA;QACAC,UAAA;MACA;MACA,KAAAV,UAAA,CAAAW,OAAA,CAAAC,CAAA;QACA,IAAAA,CAAA,CAAAC,UAAA;UACAb,UAAA,CAAAM,SAAA;QACA;UACAN,UAAA,CAAAO,WAAA;QACA;MACA;MACAP,UAAA,CAAAU,UAAA,GAAAV,UAAA,CAAAM,SAAA,GAAAN,UAAA,CAAAQ,KAAA;MACA,OAAAR,UAAA;IACA;IACAc,SAAA;MACA,YAAAT,IAAA,CAAAK,UAAA;IACA;EACA;AACA","ignoreList":[]}]}